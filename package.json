{
	"name": "treat-links-like-words",
	"version": "1.0.0",
	"description": "Obsidian plugin that makes wikilinks and Markdown links behave as single words for word-wise cursor movement, selection, and deletion.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "jest"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"links",
		"wikilinks",
		"editor"
	],
	"author": "Michael Pipolo <mapipolo@gmail.com>",
	"license": "MIT",
	"devDependencies": {
		"@types/jest": "^29.5.12",
		"@types/node": "^20.11.0",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.20.0",
		"jest": "^29.7.0",
		"obsidian": "latest",
		"ts-jest": "^29.1.2",
		"tslib": "^2.6.2",
		"typescript": "^5.3.3"
	}
}
